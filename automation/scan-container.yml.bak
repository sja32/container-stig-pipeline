- name: Container STIG Pipeline Scan (Dashboard Enabled)
  hosts: all
  gather_facts: false

  vars:
    reports_dir: "/home/allensj/projects/security/container-stig-pipeline/reports"
    timestamp: "{{ lookup('pipe', 'date +%Y%m%d-%H%M%S') }}"
    dashboard_file: "{{ reports_dir }}/dashboard.html"

  tasks:

    - name: Ensure reports directory exists
      file:
        path: "{{ reports_dir }}"
        state: directory

    ##################################################
    # BASELINE SCAN (nginx-secure)
    ##################################################

    - name: Scan baseline container (JSON)
      command: /usr/bin/trivy image nginx-secure --format json
      register: baseline_scan
      ignore_errors: yes

    - name: Count MEDIUM vulnerabilities (baseline)
      set_fact:
        baseline_medium: "{{ (baseline_scan.stdout | from_json).Results
                             | map(attribute='Vulnerabilities') | select('defined')
                             | sum(start=[])
                             | selectattr('Severity','equalto','MEDIUM')
                             | list | length }}"

    ##################################################
    # PRODUCTION SCAN (nginx-bad)
    ##################################################

    - name: Scan production container (JSON)
      command: /usr/bin/trivy image nginx-bad --format json
      register: production_scan
      ignore_errors: yes

    - name: Count MEDIUM vulnerabilities (production)
      set_fact:
        production_medium: "{{ (production_scan.stdout | from_json).Results
                               | map(attribute='Vulnerabilities') | select('defined')
                               | sum(start=[])
                               | selectattr('Severity','equalto','MEDIUM')
                               | list | length }}"

    ##################################################
    # GENERATE DASHBOARD
    ##################################################

    - name: Generate HTML dashboard
      copy:
        dest: "{{ dashboard_file }}"
        content: |
          <html>
          <head>
            <meta charset="UTF-8">
            <title>Container Security Dashboard</title>

            <style>
              body {
                font-family: Arial, sans-serif;
                background: linear-gradient(135deg, #1d1160, #00788c);
                color: white;
                padding: 20px;
              }

              h1 {
                text-align: center;
                color: #00ffff;
              }

              .card {
                background-color: rgba(0,0,0,0.6);
                border: 2px solid #00ffff;
                padding: 20px;
                margin: 20px auto;
                border-radius: 12px;
                width: 70%;
                box-shadow: 0 0 15px #00ffff;
              }

              .status-pass {
                color: #00ffcc;
                font-size: 32px;
                font-weight: bold;
              }

              .status-fail {
                color: #ff4d4d;
                font-size: 32px;
                font-weight: bold;
              }

              .label {
                color: #00ffff;
                font-weight: bold;
              }
            </style>
          </head>

          <body>

            <h1>🐝 Container Security Dashboard</h1>

            <div class="card">
              <h2>Baseline Image (nginx-secure)</h2>
              <p><span class="label">Medium Vulnerabilities:</span> {{ baseline_medium }}</p>
            </div>

            <div class="card">
              <h2>Production Image (nginx-bad)</h2>
              <p><span class="label">Medium Vulnerabilities:</span> {{ production_medium }}</p>
            </div>

            <div class="card">
              <h2>Compliance Status</h2>

              {% if production_medium > baseline_medium %}
              <div class="status-fail">FAILED ❌</div>
              {% else %}
              <div class="status-pass">PASSED ✅</div>
              {% endif %}

            </div>

          </body>
          </html>


    - name: Deploy dashboard to nginx web root
      become: true
      copy:
        src: "{{ dashboard_file }}"
        dest: /var/www/html/index.html
        remote_src: true
        owner: www-data
        group: www-data
        mode: '0644'
